<%- partial('_partial/bg-cover') %>

<style>
    .hexo-douban-picture img {
        width: 100%;
    }

	/* --- 全局容器优化 --- */
	.douban-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 20px;
	}

	/* --- 标题区域美化 --- */
	.douban-header {
		text-align: center;
		margin-bottom: 40px;
		padding: 30px 0;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		border-radius: 15px;
		color: white;
		box-shadow: 0 10px 20px rgba(0,0,0,0.1);
	}

	.douban-header h1 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 10px;
		letter-spacing: 1px;
	}

	.douban-header .quote {
		font-size: 1.8rem;
		opacity: 0.9;
		font-style: italic;
	}

	/* --- 网格布局系统 (响应式) --- */
	.douban-items {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 25px;
		padding: 10px;
	}

	/* --- 单个卡片样式 --- */
	.douban-item {
		background: #fff;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 4px 15px rgba(0,0,0,0.05);
		transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
		position: relative;
		display: flex;
		flex-direction: column;
		height: 100%;
		
	}

	.douban-item:hover {
		transform: translateY(-8px);
		box-shadow: 0 12px 30px rgba(0,0,0,0.15);
	}

	/* --- 封面图片处理 --- */
	.douban-item .cover {
		width: 100%;
		height: 400px; /* 固定高度保持整齐 */
		object-fit: cover;
		display: block;
		transition: transform 0.5s ease;
	}

	.douban-item:hover .cover {
		transform: scale(1.05);
	}

	.cover-wrapper {
		overflow: hidden;
		position: relative;
	}

	/* --- 评分标签 --- */
	.rating-badge {
		position: absolute;
		top: 10px;
		right: 10px;
		background: rgba(0, 0, 0, 0.7);
		color: #ffd700;
		padding: 4px 8px;
		border-radius: 20px;
		font-weight: bold;
		font-size: 0.9rem;
		backdrop-filter: blur(4px);
		z-index: 2;
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.rating-badge::before {
		content: '★';
		color: #ffd700;
	}

	/* --- 内容区域 --- */
	.item-content {
		padding: 20px;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		font-size:16px;
	}

	.item-title {
		font-size: 1.2rem;
		font-weight: 600;
		color: #2c3e50;
		margin-bottom: 10px;
		line-height: 1.4;
		/* 限制标题两行显示 */
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.item-meta {
		font-size: 0.85rem;
		color: #7f8c8d;
		margin-bottom: 15px;
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.item-meta span {
		background: #f0f2f5;
		padding: 2px 8px;
		border-radius: 4px;
		
	}

	.item-comment {
		font-size: 0.9rem;
		color: #555;
		line-height: 1.6;
		margin-top: auto; /* 推到底部 */
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		border-top: 1px solid #eee;
		padding-top: 15px;
	}

	/* --- 链接按钮 --- */
	.item-link {
		display: block;
		text-align: center;
		background: #667eea;
		color: white;
		padding: 10px;
		text-decoration: none;
		font-weight: 500;
		transition: background 0.3s;
	}

	.item-link:hover {
		background: #5a6fd6;
	}

	/* --- 加载状态与空状态 --- */
	.douban-loading {
		text-align: center;
		padding: 50px;
		color: #666;
	}

	.douban-empty {
		text-align: center;
		padding: 50px;
		color: #999;
	}

	/* --- 移动端适配 --- */
	@media (max-width: 768px) {
		.douban-items {
			grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
			gap: 15px;
		}
		
		.douban-item .cover {
			height: 240px;
		}
		
		.item-content {
			padding: 12px;
		}
		
		.item-title {
			font-size: 1rem;
		}
		
		.douban-header h1 {
			font-size: 1.8rem;
		}
	}
	
	.douban-item .tag, 
	.douban-item .status, 
	.item .tag, 
	.item .status {
		font-size: 15px !important; /* 这里修改字体大小，默认通常为 14px */
		padding: 2px 6px !important; /* 调整内边距，使标签更紧凑 */
		border-radius: 4px !important;
		margin-right: 5px !important;
	}
	
	
	
	.comment .short{
	
		font-size: 18px !important;
	}
}
	
	/* 标签/分类 (如: 剧情 / 犯罪) */
	.info span {
		font-size: 16px !important; /* 【修改这里】标签大小 */
		padding: 2px 8px !important;
		background-color: #f0f0f0 !important;
		border-radius: 2px !important;
		margin-right: 5px !important;
	}

</style>

<main class="content">
    <div class="navi-height bg-content pd-header ">
        <div class="card">
            <div class="card-content" style="padding: 30px;">
                <h1 style="margin: 10px 5px 10px 1px;text-align: center;font-size: 2.3rem"><%= page.title %></h1>
                <%- page.content %>
            </div>
        </div>
		 <span style="margin: 10px 10px 10px 36px;color:green;">如果你有好的想法或者内容推荐，欢迎在下面留言！</span>
       
        <div class="card">
            <% if (theme.gitalk && theme.gitalk.enable) { %>
            <%- partial('_partial/gitalk') %>
            <% } %>

            <% if (theme.gitment.enable) { %>
            <%- partial('_partial/gitment') %>
            <% } %>

            <% if (theme.disqus.enable) { %>
            <%- partial('_partial/disqus') %>
            <% } %>

            <% if (theme.livere && theme.livere.enable) { %>
            <%- partial('_partial/livere') %>
            <% } %>

            <% if (theme.valine && theme.valine.enable) { %>
            <%- partial('_partial/valine') %>
            <% } %>
        </div>
    </div>
</main>

