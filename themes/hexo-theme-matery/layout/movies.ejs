<%- partial('_partial/bg-cover') %>

<main class="content">

<div class="navi-height bg-cover pd-header ">

</div>


</main>




<% if (theme.banner.enable) { %>
    <script>
        // 每天切换 banner 图.  Switch banner image every day.
        $('.bg-cover').css('background-image', 'url(/medias/banner/' + new Date().getDay() + '.jpg)');
    </script>
<% }  else if (theme.banner.url && theme.banner.url.length > 0) { %>
<script>
	//显示自己定义的图片
    $('.bg-cover').css('background-image', 'url(<%- theme.jsDelivr.url %><%- url_for(theme.banner.url) %>)');
</script>
<% }else { %>
    <script>
        $('.bg-cover').css('background-image', 'url(/medias/banner/0.jpg)');
    </script>
<% } %>