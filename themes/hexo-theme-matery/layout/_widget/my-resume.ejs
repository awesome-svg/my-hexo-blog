						#3498db 0% , 93% /* 使用CSS变量会更灵活，但此处直接写值 */
						#ecf0f1 93% 100%
					);*/
					z-index: 1;
				}

				/* 创建内层白色圆 var(--percentage)*/
				.skill-item::after {
					content: '';
					position: absolute;
					top: 50%;
					left: 50%;
					transform: translate(-50%, -50%);
					width: 80%;
