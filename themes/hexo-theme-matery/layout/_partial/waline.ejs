<% if (theme.waline && theme.waline.enable) { %>
  <!-- 1. 容器 -->
  <div id="waline" style="margin-top: 20px;"></div>

  <!-- 2. 引入 Waline JS库 (必须在前) -->
  <script src="https://unpkg.com/@waline/client@v2/dist/waline.js"></script>

  <!-- 3. 初始化脚本 (必须在后) -->
  <script>
    // 等待 DOM 和 Waline 库都加载完毕
    window.addEventListener('load', function() {
      // 双重检查：确保库已加载且容器存在
      if (typeof Waline === 'undefined') {
        console.error('❌ Waline 库加载失败，请检查网络或 CDN');
        return;
      }
      
      const container = document.getElementById('waline');
      if (!container) {
        console.error('❌ 未找到 #waline 容器');
        return;
      }

      try {
        // 初始化
        Waline.init({
          el: '#waline',
          // 【关键】替换为你自己的服务端地址，不要留空！
          serverURL: '<%= theme.waline.serverURL %>', 
          path: window.location.pathname,
          lang: 'zh-CN',
          emoji: [
            '//unpkg.com/@waline/emojis@1.1.0/weibo',
            '//unpkg.com/@waline/emojis@1.1.0/bilibili'
          ],
          requiredMeta: ['nick', 'mail'],
          // 开启调试模式，方便看报错
          debug: true 
        });
        console.log('✅ Waline 初始化成功');
      } catch (e) {
        console.error('❌ Waline 初始化出错:', e);
      }
    });
  </script>
<% } %>
